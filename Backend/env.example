# SkillLink Services Backend Environment Configuration

# App Configuration
app.baseURL = 'http://localhost:8080'
app.indexPage = 'index.php'
app.appTimezone = 'Asia/Manila'
app.defaultLocale = 'en'

# Database Configuration
database.default.hostname = localhost
database.default.database = skilllink_services
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPrefix = 
database.default.port = 3306

# Session Configuration
session.driver = file
session.cookieName = skilllink_session
session.expiration = 7200
session.savePath = WRITEPATH . 'session'
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = false

# Cookie Configuration
cookie.prefix = skilllink_
cookie.expires = 86400
cookie.path = /
cookie.domain = 
cookie.secure = false
cookie.httponly = false
cookie.samesite = Lax
cookie.raw = false

# Encryption Configuration
encryption.key = 
encryption.driver = OpenSSL
encryption.blockSize = 16
encryption.encrypt = true

# JWT Configuration
JWT_SECRET = your-super-secret-jwt-key-change-this-in-production

# Email Configuration
email.fromEmail = admin@skilllink.com
email.fromName = SkillLink Services
email.SMTPHost = 
email.SMTPUser = 
email.SMTPPass = 
email.SMTPPort = 587
email.SMTPTimeout = 5
email.SMTPCrypto = TLS

# File Upload Configuration
upload.maxFileSize = 10485760
upload.allowedTypes = gif,jpg,jpeg,png,pdf,doc,docx
upload.uploadPath = WRITEPATH . 'uploads'

# CORS Configuration (for API)
cors.allowedOrigins = *
cors.allowedMethods = GET,POST,PUT,DELETE,OPTIONS
cors.allowedHeaders = Content-Type,Authorization
cors.allowCredentials = true

# Cache Configuration
cache.handler = file
cache.prefix = skilllink_
cache.ttl = 3600

# Logging Configuration
logger.threshold = 4
logger.handler = file

# Debug Configuration
CI_ENVIRONMENT = development
displayErrors = 1
errorReporting = E_ALL

# API Configuration
api.rateLimit = 100
api.rateLimitWindow = 3600
api.version = v1

# Payment Gateway Configuration (for future integration)
payment.gateway = sandbox
payment.merchant_id = 
payment.secret_key = 
payment.webhook_url = 

# SMS Configuration (for future integration)
sms.provider = 
sms.api_key = 
sms.api_secret = 

# Push Notification Configuration (for future integration)
push.provider = 
push.api_key = 
push.auth_domain = 
push.project_id =
